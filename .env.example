WP_BASE_URL=https://api.takhfid.nl
# Override this if WordPress REST is hosted somewhere other than /wp-json/wp/v2.
WP_REST_BASE_URL=https://api.takhfid.nl/wp-json/wp/v2
WP_USERNAME=your-wordpress-username
WP_APP_PASSWORD=your-wordpress-application-password
WP_DESTINATION_POST_TYPE=destination
WP_TICKET_POST_TYPE=ticket
WP_DEAL_POST_TYPE=deal

# Set to true only when your WordPress REST API has these meta keys registered.
WP_WRITE_META=false

# Gemini (optional for AI features)
GEMINI_API_KEY=

# Local app admin login
# Username is always: admin
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_SECRET=change-this-random-session-secret

# WordPress REST API - required for Insert to WordPress / create & update
WP_BASE_URL=https://api.takhfid.nl
WP_USERNAME=your-wordpress-username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Optional overrides
# WP_REST_BASE_URL=https://api.takhfid.nl/wp-json/wp/v2
